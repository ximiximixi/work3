paper/*.pdf
!/paper/cv_defect_detection_report_updated.pdf
paper/*.aux
paper/*.log
paper/*.out
paper/*.toc
paper/*.listing
paper/*.fdb_latexmk
paper/*.fls
paper/*.xdv
paper/*.synctex.gz
paper/hpc_ch2.*

