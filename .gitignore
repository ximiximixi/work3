!/cap_annotation_tool/server.py
!/cap_annotation_tool/index.html
!/cap_annotation_tool/app.js
!/cap_annotation_tool/style.css
cap_annotation_tool/*.json
cap_annotation_tool/*.csv
cap_annotation_tool/*.jpg
cap_annotation_tool/frames/
cap_annotation_tool/side_roi_crops/
cap_annotation_tool/__pycache__/

!/paper/
