# Keep source code and report files versioned while leaving large videos,
# generated outputs, model caches, and extracted frames ignored.
!/README.md
!/advanced_defect_analysis.py
!/cap_defect_detection_pipeline.py
!/defect_detection_pipeline.py
!/make_side_micro_showcase_video.py
!/prepare_cap_annotation_set.py
!/requirements_defect_pipeline.txt

!/cap_annotation_tool/
